---
// Giscus comment widget — blog post comments backed by GitHub Discussions.
// Category = Announcements (giscus recommendation: only repo admins can create
// new threads there, giscus bot creates one per post on first visit).
---
<section class="mx-auto max-w-[680px] mt-16 pt-8 border-t border-border">
  <script
    src="https://giscus.app/client.js"
    data-repo="urunimi/urunimi.github.io"
    data-repo-id="R_kgDOEIcVFg"
    data-category="Announcements"
    data-category-id="DIC_kwDOEIcVFs4C7VZN"
    data-mapping="pathname"
    data-strict="0"
    data-reactions-enabled="1"
    data-emit-metadata="0"
    data-input-position="bottom"
    data-theme="light"
    data-lang="ko"
    crossorigin="anonymous"
    async
  ></script>
</section>
